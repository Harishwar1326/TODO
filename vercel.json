{
  "version": 2,
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } },
    { "src": "backend/api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/tasks(?:/(.*))?", "dest": "/backend/api/tasks.js" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
